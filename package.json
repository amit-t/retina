{
  "name": "retina",
  "version": "0.0.0",
  "description": "Self-hostable image understanding API backed by pluggable vision LLM providers.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run --project unit --project replay --project e2e",
    "test:unit": "vitest run --project unit",
    "test:replay": "vitest run --project replay",
    "test:e2e": "vitest run --project e2e",
    "test:live": "vitest run --project live"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.96",
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@hono/node-server": "^2.0.0",
    "ai": "^6.0.168",
    "hono": "^4.12.14",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  }
}
